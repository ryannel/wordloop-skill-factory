{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wordloop.dev/schemas/skills-docs-map.schema.json",
  "title": "Wordloop Skill Docs Map",
  "type": "object",
  "required": ["version", "skills"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skill", "source_path", "consumed_path", "canonical_docs", "owner"],
        "properties": {
          "skill": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "source_path": { "type": "string" },
          "consumed_path": { "type": "string" },
          "canonical_docs": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "uniqueItems": true
          },
          "secondary_docs": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "owner": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
